{
  "entities": {
    "ResearcherProfile": {
      "title": "Researcher Profile",
      "description": "Profile data for a researcher",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "status": { "type": "string", "enum": ["Pendente", "Ativo", "Inativo", "Rejeitado", "Pendência", "Em Análise"] },
        "nome": { "type": "string" },
        "cpf": { "type": "string" },
        "nascimento": { "type": "string" },
        "nome_mae": { "type": "string" },
        "nome_pai": { "type": "string" },
        "naturalidade": { "type": "string" },
        "nacionalidade": { "type": "string" },
        "passaporte": { "type": "string" },
        "inss": { "type": "string" },
        "pis": { "type": "string" },
        "email_inst": { "type": "string", "format": "email" },
        "email_pess": { "type": "string", "format": "email" },
        "telefone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "cep": { "type": "string" },
        "logradouro": { "type": "string" },
        "complemento": { "type": "string" },
        "cidade": { "type": "string" },
        "uf": { "type": "string" },
        "vinculo": { "type": "string" },
        "matricula": { "type": "string" },
        "carga_horaria": { "type": "number" },
        "regional": { "type": "string" },
        "tipo_unidade": { "type": "string" },
        "lotacao": { "type": "string" },
        "setor": { "type": "string" },
        "cep_inst": { "type": "string" },
        "end_inst": { "type": "string" },
        "sei": { "type": "string" },
        "graduacao": { "type": "string" },
        "titulacao": { "type": "string" },
        "area": { "type": "string" },
        "lattes": { "type": "string" },
        "orcid": { "type": "string" },
        "orcid_link": { "type": "string" },
        "historico_json": { "type": "string" },
        "banco": { "type": "string" },
        "agencia": { "type": "string" },
        "tipo_conta": { "type": "string" },
        "conta": { "type": "string" },
        "genero": { "type": "string" },
        "raca": { "type": "string" },
        "ensino_medio": { "type": "string" },
        "beneficiario": { "type": "string" },
        "pcd": { "type": "string" },
        "pcd_detalhe": { "type": "string" },
        "atuacao": { "type": "string" },
        "detalhes_atuacao": { "type": "string" },
        "grupo_cnpq": { "type": "string" },
        "documentos_json": { "type": "string" },
        "document_statuses": { "type": "string" },
        "rejection_message": { "type": "string" },
        "allow_correction": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "nome", "cpf", "email_inst"]
    },
    "Project": {
      "title": "Project",
      "description": "A project submitted by a researcher (Fomento à Pesquisa, Fomento para Publicação, or PICITE)",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "type": { "type": "string", "enum": ["fomento_pesquisa", "fomento_publicacao", "picite"] },
        "status": { "type": "string", "enum": ["Rascunho", "Em Análise", "Aprovado", "Pendente", "Rejeitado", "Pendência", "Cancelado pelo Pesquisador", "Em Execução", "Concluído"] },
        "raw_data": { "type": "string", "description": "JSON string containing project specific data" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "type", "status", "raw_data"]
    },
    "Message": {
      "title": "Message",
      "description": "A message between SIEPES and a researcher",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "projectId": { "type": "string" },
        "from": { "type": "string" },
        "text": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "from", "text", "read"]
    },
    "Signature": {
      "title": "Signature",
      "description": "A document signature",
      "type": "object",
      "properties": {
        "authorUid": { "type": "string" },
        "projectId": { "type": "string" },
        "documentName": { "type": "string" },
        "documentUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Aprovado", "Rejeitado"] },
        "rejectionMessage": { "type": "string" },
        "signedBy": { "type": "string" },
        "signedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorUid", "documentName", "status"]
    }
  },
  "firestore": {
    "/researchers/{userId}": {
      "schema": { "$ref": "#/entities/ResearcherProfile" },
      "description": "Profiles of researchers"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "All projects"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "All messages"
    },
    "/signatures/{signatureId}": {
      "schema": { "$ref": "#/entities/Signature" },
      "description": "All document signatures"
    }
  }
}
